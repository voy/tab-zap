{
  "manifest_version": 3,
  "name": "Tab Zap",
  "version": "1.5.2",
  "description": "Close groups of related tabs quickly",
  "background": {
    "service_worker": "background/background.bundle.js"
  },
  "commands": {
    "_execute_action": {
      "suggested_key": {
        "mac": "Command+Shift+Z",
        "default": "Ctrl+Shift+Z"
      },
      "description": "Open Tab Zap"
    }
  },
  "permissions": ["tabs"],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  }
}
